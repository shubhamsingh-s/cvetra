## Backend environment variables (example)
# MongoDB Atlas connection string (set on Render as a secret)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net
MONGO_DB=cvetra

# AI engine base URL (deployed separately)
AI_ENGINE_URL=https://your-ai-engine-on-render.example.com

# Optional: set host/port on Render
PORT=8000
PROJECT_NAME=Talentverse
API_V1_STR=/api/v1

# Security
SECRET_KEY=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING
ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7 days

# Database
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=talentverse
POSTGRES_PORT=5432

# AI
GEMINI_API_KEY=AIzaSyBe8EWtiP67sWGmegqDoXqHPAHB8UXkTTc
OPENAI_API_KEY=optional_if_using_openai

# Redis / Celery
REDIS_HOST=localhost
REDIS_PORT=6379

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]
